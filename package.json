{
  "name": "employee-operations-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "build:api": "tsc -p tsconfig.server.build.json",
    "start:api": "node server-dist/index.js",
    "test": "npm run test:security && npm run test:finalization",
    "test:security": "tsx tests/security.test.ts",
    "test:finalization": "tsx tests/finalization.test.ts",
    "create:owner": "tsx server/scripts/createOwner.ts",
    "create:temp-store": "tsx server/scripts/createTempStore.ts",
    "create:sample-stores": "tsx server/scripts/createSampleStores.ts",
    "bootstrap:store-dbs": "tsx server/scripts/bootstrapStoreDatabases.ts",
    "preview": "vite preview --host 0.0.0.0",
    "api": "tsx server/index.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "mongoose": "^8.9.2",
    "morgan": "^1.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
