# Required locally and in production
PORT=4000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/storeops?retryWrites=true&w=majority
MONGODB_DB_NAME=storeops
JWT_SECRET=replace-this-with-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173

# Optional backend tuning
HOST=0.0.0.0
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_RETRY_DELAY_MS=5000
SEED_DEMO_DATA=false

# Optional local frontend proxy
VITE_API_PROXY_TARGET=http://localhost:4000

# Required on Vercel frontend only
VITE_API_BASE_URL=https://your-backend-url

# Required only when creating the platform owner
PLATFORM_OWNER_NAME=Preet Patel
PLATFORM_OWNER_USERNAME=preet1862
PLATFORM_OWNER_EMAIL=preetpatel1862@gmail.com
PLATFORM_OWNER_PASSWORD=Use-A-Long-Unique-Password123
